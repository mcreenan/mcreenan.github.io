---
// Win95Desktop.astro — Win95 desktop icon grid for home page
// Hidden by default, shown only under [data-theme="win95"] via CSS toggle
---

<div class="win95-desktop" oncontextmenu="event.preventDefault(); window.openThemeDialog();">
  <!-- 48x48 pixel art icons, 16-color Win95 palette (per D-07) -->

  <!-- About icon: person/user silhouette — scaled from Phase 3 32x32 -->
  <a href="/about" class="win95-icon">
    <svg width="48" height="48" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" style="image-rendering: pixelated; image-rendering: crisp-edges;" aria-hidden="true">
      <!-- Head -->
      <rect x="18" y="3" width="12" height="12" fill="#000080"/>
      <rect x="19" y="4" width="10" height="10" fill="#FFFFFF"/>
      <!-- Shoulders/body -->
      <rect x="12" y="18" width="24" height="15" fill="#000080"/>
      <rect x="13" y="19" width="22" height="13" fill="#C0C0C0"/>
      <!-- Tie/accent -->
      <rect x="22" y="18" width="4" height="9" fill="#800000"/>
      <!-- Base -->
      <rect x="9" y="33" width="30" height="6" fill="#000080"/>
      <rect x="10" y="34" width="28" height="4" fill="#808080"/>
      <!-- Border -->
      <rect x="9" y="39" width="30" height="3" fill="#000000"/>
    </svg>
    <span class="win95-icon-label">About</span>
  </a>

  <!-- Work icon: briefcase — scaled from Phase 3 32x32 -->
  <a href="/work" class="win95-icon">
    <svg width="48" height="48" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" style="image-rendering: pixelated; image-rendering: crisp-edges;" aria-hidden="true">
      <!-- Handle -->
      <rect x="16" y="6" width="16" height="6" fill="#808000"/>
      <rect x="18" y="7" width="12" height="4" fill="#C0C0C0"/>
      <!-- Case body -->
      <rect x="6" y="12" width="36" height="24" fill="#808000"/>
      <rect x="7" y="13" width="34" height="22" fill="#C0C0C0"/>
      <!-- Clasp -->
      <rect x="21" y="21" width="6" height="6" fill="#808000"/>
      <rect x="22" y="22" width="4" height="4" fill="#FFFF00"/>
      <!-- Bottom -->
      <rect x="6" y="36" width="36" height="6" fill="#808000"/>
      <rect x="7" y="37" width="34" height="4" fill="#808080"/>
    </svg>
    <span class="win95-icon-label">Work</span>
  </a>

  <!-- Contact icon: envelope — scaled from Phase 3 32x32 -->
  <a href="/contact" class="win95-icon">
    <svg width="48" height="48" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" style="image-rendering: pixelated; image-rendering: crisp-edges;" aria-hidden="true">
      <!-- Envelope body -->
      <rect x="3" y="12" width="42" height="27" fill="#000080"/>
      <rect x="4" y="13" width="40" height="25" fill="#FFFFFF"/>
      <!-- Flap (top triangle approximation — scaled 1.5x) -->
      <rect x="4" y="13" width="3" height="3" fill="#000080"/>
      <rect x="7" y="16" width="3" height="3" fill="#000080"/>
      <rect x="10" y="19" width="3" height="3" fill="#000080"/>
      <rect x="13" y="22" width="3" height="3" fill="#000080"/>
      <rect x="16" y="25" width="3" height="3" fill="#000080"/>
      <rect x="19" y="28" width="3" height="3" fill="#000080"/>
      <rect x="22" y="25" width="3" height="3" fill="#000080"/>
      <rect x="25" y="22" width="3" height="3" fill="#000080"/>
      <rect x="28" y="19" width="3" height="3" fill="#000080"/>
      <rect x="31" y="16" width="3" height="3" fill="#000080"/>
      <rect x="34" y="13" width="3" height="3" fill="#000080"/>
      <rect x="37" y="13" width="3" height="3" fill="#000080"/>
      <rect x="40" y="13" width="3" height="3" fill="#000080"/>
      <!-- Stamp area -->
      <rect x="33" y="16" width="9" height="9" fill="#FF0000"/>
      <rect x="34" y="17" width="7" height="7" fill="#FFFF00"/>
    </svg>
    <span class="win95-icon-label">Contact</span>
  </a>
</div>
