---
// Taskbar.astro — Win95 taskbar with Start button and live clock
// Hidden by default, shown only under [data-theme="win95"] via CSS toggle
---

<div class="win95-taskbar">
  <button class="win95-start-btn" type="button" onclick="window.openThemeDialog()">
    <svg class="win95-start-flag" width="16" height="14" viewBox="0 0 16 14" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <!-- Artist palette -->
      <path d="M8 1C4 1 1 4 1 7.5C1 10 3 11.5 4.5 11.5C5.5 11.5 6 11 6 10.3C6 9.8 5.7 9.5 5.7 9C5.7 8.4 6.2 8 6.8 8H9C11.8 8 14 5.8 14 3C14 1.5 11.5 1 8 1Z" fill="#E8D4A0" stroke="#000000" stroke-width="0.8" stroke-linejoin="round"/>
      <circle cx="4" cy="5" r="1" fill="#FF0000"/>
      <circle cx="7" cy="3.5" r="1" fill="#FFFF00"/>
      <circle cx="10.5" cy="4" r="1" fill="#0000FF"/>
      <circle cx="11" cy="6.5" r="1" fill="#00AA00"/>
    </svg>
    <span>Change Theme</span>
  </button>
  <div class="win95-tray">
    <time class="win95-clock" id="win95-clock" datetime="">12:00 PM</time>
  </div>
</div>

<script>
  function updateWin95Clock() {
    const el = document.getElementById('win95-clock');
    if (!el) return;
    const now = new Date();
    let h = now.getHours();
    const m = now.getMinutes().toString().padStart(2, '0');
    const ampm = h >= 12 ? 'PM' : 'AM';
    h = h % 12 || 12;
    const timeStr = `${h}:${m} ${ampm}`;
    el.textContent = timeStr;
    el.setAttribute('datetime', now.toISOString());
  }
  updateWin95Clock();
  setInterval(updateWin95Clock, 60000);
  // Reinit on View Transitions navigation (per Pitfall 4 in RESEARCH.md)
  document.addEventListener('astro:after-swap', () => {
    updateWin95Clock();
  });
</script>
