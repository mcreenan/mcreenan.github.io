---
import BaseHead from "../components/BaseHead.astro";
import ThemeDialog from "../components/ThemeDialog.astro";
import ProgramManager from "../components/ProgramManager.astro";
import Win95Desktop from "../components/Win95Desktop.astro";
import Taskbar from "../components/Taskbar.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
---

<!doctype html>
<html lang="en" data-theme="retro">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<main class="h-screen overflow-hidden">
			<section class="flex flex-col items-center justify-center h-full">
				<div class="retro-layout flex flex-col items-center justify-center h-full">
					<div class="window fixed splash-screen">
						<div class="window-inner">
							<div
								class="flex items-center justify-center mt-8 gap-6"
							>
								<img
									src="/images/headshot.png"
									alt="Matt Creenan"
									class="headshot-image"
								/>
								<h1 class="text-6xl font-bold os-title">
									Matt Creenan
								</h1>
							</div>
							<div
								class="flex justify-center items-center mt-8 md:mt-12 flex-wrap gap-4"
								style="height: auto; min-height: 120px;"
							>
								<a
									href="/about"
									class="button flex flex-col justify-between py-2"
								>
									<i class="ph ph-user text-4xl"></i>
									<span>About</span>
								</a>
								<a
									href="/work"
									class="button flex flex-col justify-between py-2"
								>
									<i class="fa-regular fa-building text-4xl"></i>
									<span>Work</span>
								</a>
								<a
									href="/contact"
									class="button flex flex-col justify-between py-2"
								>
									<i class="ph ph-envelope text-4xl"></i>
									<span>Contact</span>
								</a>
								<button
									class="button flex flex-col justify-between py-2"
									type="button"
									onclick="window.openThemeDialog()"
								>
									<i class="ph ph-palette text-4xl"></i>
									<span>Themes</span>
								</button>
							</div>
						</div>
					</div>
				</div>
				<ProgramManager />
				<Win95Desktop />

				<div id="overlay-window" role="dialog" aria-modal="true" aria-label="Content" hidden>
					<div class="overlay-backdrop"></div>
					<div class="overlay-chrome overlay-chrome-win31 window splash-screen">
						<div class="window-titlebar">
							<div class="win31-titlebar-left">
								<button class="win31-chrome-btn overlay-close" aria-label="Close" type="button">-</button>
							</div>
							<span class="window-title overlay-title"></span>
							<div class="win31-titlebar-right">
								<span class="win31-chrome-btn win31-btn-raised" aria-hidden="true">&#9650;</span>
								<span class="win31-chrome-btn win31-btn-raised" aria-hidden="true">&#9660;</span>
							</div>
						</div>
						<div class="window-inner">
							<div class="window-content overlay-body"></div>
						</div>
					</div>
					<div class="overlay-chrome overlay-chrome-win95 window splash-screen">
						<div class="title-bar">
							<div class="title-bar-text overlay-title"></div>
							<div class="title-bar-controls">
								<button aria-label="Minimize" type="button"></button>
								<button aria-label="Maximize" type="button"></button>
								<button class="overlay-close" aria-label="Close" type="button"></button>
							</div>
						</div>
						<div class="window-body overlay-body"></div>
					</div>
				</div>
			</section>
		<ThemeDialog />
		<Taskbar />
	</main>
	<script>
		// === Desktop Overlay Controller (Phase 05) ===

		const contentCache = new Map<string, { title: string; html: string }>();
		let overlayIsOpen = false;
		let activeTrigger: HTMLElement | null = null;

		const TITLE_MAP: Record<string, string> = {
			'/about': 'About Me',
			'/work': 'Work',
			'/contact': 'Contact',
		};

		const FOCUSABLE = 'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])';

		function initDesktopOverlay() {
			const theme = document.documentElement.getAttribute('data-theme');
			if (theme !== 'win31' && theme !== 'win95') return;

			const icons = document.querySelectorAll<HTMLAnchorElement>('.pm-icon, .win95-icon');
			icons.forEach((anchor) => {
				anchor.addEventListener('click', (e) => {
					e.preventDefault();
					e.stopPropagation();
					const href = anchor.getAttribute('href');
					if (href) openOverlay(href, anchor);
				});
			});
		}

		async function openOverlay(url: string, triggerEl: HTMLElement) {
			activeTrigger = triggerEl;
			overlayIsOpen = true;

			if (!contentCache.has(url)) {
				const resp = await fetch(url);
				const text = await resp.text();
				const doc = new DOMParser().parseFromString(text, 'text/html');

				const contentEl = doc.querySelector('.window-content') || doc.querySelector('.window-body');
				const html = contentEl ? contentEl.innerHTML : '';
				const title = TITLE_MAP[url] || 'Content';

				contentCache.set(url, { title, html });
			}

			const cached = contentCache.get(url)!;
			const overlay = document.getElementById('overlay-window');
			if (!overlay) return;

			overlay.querySelectorAll('.overlay-title').forEach((el) => {
				el.textContent = cached.title;
			});
			overlay.querySelectorAll('.overlay-body').forEach((el) => {
				el.innerHTML = cached.html;
			});

			overlay.removeAttribute('hidden');
			history.pushState({ overlayUrl: url }, '', url);

			// Focus the close button in the visible chrome
			const visibleClose = overlay.querySelector<HTMLElement>('.overlay-chrome:not([style*="display: none"]) .overlay-close');
			if (visibleClose) {
				visibleClose.focus();
			} else {
				// Fallback: focus any visible close button
				const anyClose = overlay.querySelector<HTMLElement>('.overlay-close');
				if (anyClose) anyClose.focus();
			}
		}

		function closeOverlay(fromPopstate = false) {
			if (!overlayIsOpen) return;
			overlayIsOpen = false;

			const overlay = document.getElementById('overlay-window');
			if (overlay) {
				overlay.setAttribute('hidden', '');
				overlay.querySelectorAll('.overlay-body').forEach((el) => {
					el.innerHTML = '';
				});
			}

			if (!fromPopstate) {
				history.back();
			}

			activeTrigger?.focus();
			activeTrigger = null;
		}

		// Focus trap and Escape key handler
		const overlayEl = document.getElementById('overlay-window');
		if (overlayEl) {
			overlayEl.addEventListener('keydown', (e) => {
				if (e.key === 'Escape') {
					closeOverlay();
					return;
				}

				if (e.key === 'Tab') {
					const focusable = Array.from(overlayEl.querySelectorAll<HTMLElement>(FOCUSABLE));
					if (focusable.length === 0) return;

					const first = focusable[0];
					const last = focusable[focusable.length - 1];

					if (e.shiftKey && document.activeElement === first) {
						e.preventDefault();
						last.focus();
					} else if (!e.shiftKey && document.activeElement === last) {
						e.preventDefault();
						first.focus();
					}
				}
			});

			// Backdrop click handler
			const backdrop = overlayEl.querySelector('.overlay-backdrop');
			if (backdrop) {
				backdrop.addEventListener('click', () => closeOverlay());
			}

			// Close button handlers
			overlayEl.querySelectorAll('.overlay-close').forEach((btn) => {
				btn.addEventListener('click', () => closeOverlay());
			});
		}

		// Back button handler
		window.addEventListener('popstate', () => {
			if (!overlayIsOpen) return;
			closeOverlay(true);
		});

		// astro:after-swap re-initialization
		document.addEventListener('astro:after-swap', () => {
			overlayIsOpen = false;
			contentCache.clear();
			initDesktopOverlay();
		});

		initDesktopOverlay();
	</script>
	</body>
</html>
